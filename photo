#!/usr/bin/env bash
# PhotoTochka Control CLI
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

# Цвета для вывода
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

info() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

usage() {
  echo "Использование: ./photo <команда>"
  echo "  up           Запуск Docker-контейнеров"
  echo "  down         Остановка Docker-контейнеров"
  echo "  dev:back     Запуск бэкенда локально (python)"
  echo "  dev:front    Запуск фронтенда локально (npm)"
  echo "  build        Полная сборка проекта"
  echo "  test:back    Запуск тестов бэкенда (pytest)"
  echo "  test:full    Полный цикл тестов (back + front lint + E2E)"
  echo "  seed         Наполнение базы демо-данными"
  echo "  deploy       Деплой на VDS (через rsync + ssh)"
  echo "  help         Показать это сообщение"
}

check_env() {
  if [ ! -f .env ]; then
    info "Файл .env не найден. Копирую из .env.example..."
    cp .env.example .env
  fi
  if [ ! -f backend/.env ]; then
    cp backend/.env.example backend/.env
  fi
}

case "${1:-}" in
  up)
    check_env
    docker compose up -d
    info "Ожидаю готовности бэкенда..."
    for i in {1..30}; do
      if curl -s http://localhost:8000/admin/ > /dev/null; then
        info "Бэкенд готов!"
        exit 0
      fi
      sleep 1
    done
    error "Бэкенд не запустился за 30 секунд. Проверьте логи: docker compose logs backend"
    ;;

  down)
    docker compose down
    ;;

  dev:back)
    check_env
    cd backend
    source .venv/bin/activate || error "Виртуальное окружение не найдено. Запустите сначала установку зависимостей."
    python manage.py migrate
    python manage.py runserver 8000
    ;;

  dev:front)
    cd frontend
    npm install
    npm run dev
    ;;

  build)
    info "Сборка фронтенда..."
    (cd frontend && npm install && npm run build)
    info "Сборка бэкенда (collectstatic)..."
    (cd backend && source .venv/bin/activate && python manage.py collectstatic --noinput)
    info "Сборка завершена!"
    ;;

  test:back)
    cd backend && source .venv/bin/activate && pytest
    ;;

  test:full)
    info "Запуск тестов бэкенда..."
    (cd backend && source .venv/bin/activate && pytest) || error "Тесты бэкенда провалены"
    
    info "Проверка типов фронтенда..."
    (cd frontend && npm run lint) || warn "Проверка типов фронтенда нашла ошибки"
    
    info "Запуск E2E тестов (Playwright)..."
    (cd frontend && npx playwright test) || error "E2E тесты провалены"
    ;;

  seed)
    cd backend && source .venv/bin/activate && python manage.py seed_demo
    ;;

  deploy)
    bash scripts/internal/deploy.sh
    ;;

  help|--help|-h|"")
    usage
    ;;

  *)
    warn "Неизвестная команда: $1"
    usage
    exit 1
    ;;
esac
