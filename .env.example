# Frontend (Vite)
VITE_API_URL=http://localhost:8000
# Базовый путь API для fetch (прокси Vite по умолчанию: /api)
# VITE_API_BASE_PATH=/api
# Абсолютный URL картинки Open Graph по умолчанию (иначе — брендовый ассет из бандла)
# VITE_DEFAULT_OG_IMAGE=https://example.com/og-default.jpg

# Backend (Django)
DJANGO_SECRET_KEY=django-insecure-development-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Сборка Docker-образа бэкенда: при таймаутах/SSL к PyPI задайте зеркало индекса
# (docker compose читает .env и передаёт в build args)
# PIP_INDEX_URL=https://pypi.org/simple

# --- Media pipeline: Celery, кэш витрины, S3 ---
# Пустой CELERY_BROKER_URL — задачи выполняются синхронно (eager), Redis не обязателен для dev.
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# Кэш Django (к примеру для GET /api/showcase/); >0 только если задан REDIS_URL
# REDIS_URL=redis://127.0.0.1:6379/1
# SHOWCASE_CACHE_SECONDS=0
# S3-совместимое хранилище: все три — для включения django-storages
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=https://s3.example.com
# AWS_S3_REGION_NAME=ru-1

# Admin Seeding
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin-password-change-me

# Deployment
PHOTO_DEPLOY_HOST=ваша-вдс.com
PHOTO_DEPLOY_USER=root
PHOTO_DEPLOY_PATH=/opt/phototochka
