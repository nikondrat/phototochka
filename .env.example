# Публичный канонический URL (без завершающего слэша). Для продакшена задайте реальный домен.
VITE_SITE_URL=http://127.0.0.1:5173

# Демо-вход в админку (mock, не прод). Скопируйте в .env и задайте свои значения.
VITE_DEMO_ADMIN_EMAIL=demo@example.com
VITE_DEMO_ADMIN_PASSWORD=change-me
# VITE_DEMO_ADMIN_DISPLAY_NAME=Администратор

# Яндекс.Метрика и верификация вебмастера — опционально; без ID счётчик не загружается.
# VITE_YANDEX_METRICA_ID=
# VITE_YANDEX_SITE_VERIFICATION=
